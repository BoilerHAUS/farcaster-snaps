{
  "name": "@farcaster-snaps/clanker-tips",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "SKIP_JFS_VERIFICATION=true tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "bash -c 'bash package-for-host-neynar.sh /tmp/clanker-tips.tar.gz && source .agentdeploy && curl -X POST https://api.host.neynar.app/v1/deploy -F files=@/tmp/clanker-tips.tar.gz -F projectName=clanker-tips -F framework=hono -H \"Authorization: Bearer ${apiKey}\"'"
  },
  "dependencies": {
    "@farcaster/snap": "^1.20.0",
    "@farcaster/snap-hono": "^1.5.9",
    "@farcaster/snap-turso": "^1.0.18",
    "@hono/node-server": "^1.19.13",
    "@noble/curves": "^2.0.0",
    "hono": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
